<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WinUiTest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUiTest"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WinUiTest">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Margin="270,0,0,0">
        <DatePicker 
            x:Name="datePickerDate" 
            Date="{x:Bind ViewModel.SelectedDate, Mode=TwoWay}" 
            HorizontalAlignment="Left" 
            Margin="-247,35,0,0" 
            VerticalAlignment="Top"/>
        <Button 
            x:Name="btnAdd" 
            Content="Hinzufügen" 
            HorizontalAlignment="Left" 
            Margin="-247,82,0,0" 
            VerticalAlignment="Top" 
            Click="AddToList"/>
        <ListView x:Name="listViewDates"
                  ItemsSource="{x:Bind ViewModel.Dates}"
                  SelectedItem="{x:Bind ViewModel.SelectedText, Mode=TwoWay}"
                  SelectionChanged="SelectedItem"
                  SelectionMode="Single"
                  Margin="64,22,28,36">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <TextBlock Text="{x:Bind}" FontSize="16"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
